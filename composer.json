{
  "name": "letsdank/swissphp",
  "description": "A PHP port of Swiss Ephemeris with astronomical calculations and PHPUnit coverage.",
  "type": "library",
  "license": "AGPL-3.0-or-later",
  "keywords": [
    "astronomy",
    "astrology",
    "ephemeris",
    "swiss-ephemeris",
    "php"
  ],
  "autoload": {
    "psr-4": {
      "SwissEph\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "SwissEph\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": ">=8.4"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5 || ^12.0"
  }
}
